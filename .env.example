# =============================================================================
# Portfolio environment variables — copy to .env.local and fill in.
# =============================================================================

# -----------------------------------------------------------------------------
# Ably — multiplayer cursors + reactions (free 6M msgs/mo, no branding)
# -----------------------------------------------------------------------------
# Sign up at https://ably.com → Apps → API Keys → copy the *root* key.
# Server-side only: the /api/ably/token route mints short-lived tokens.
ABLY_API_KEY=xxxxxxxx.xxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Build-time flag that gates the multiplayer feature on. Without "1", the
# cursor/reaction layer renders nothing.
NEXT_PUBLIC_MULTIPLAYER_ENABLED=1

# -----------------------------------------------------------------------------
# Groq — chat assistant ("Ask about Keshav") with smart 8B/70B routing
# -----------------------------------------------------------------------------
# Sign up at https://console.groq.com (free tier covers ~14K req/day).
# Used by /api/chat. Without this, the chat widget will return 500 on send.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# GitHub — fetched at build time by scripts/fetch-github.mjs and baked into
# the chat assistant's knowledge base.
# -----------------------------------------------------------------------------
# Optional: Personal Access Token (no scopes needed for public repos).
# Without it, the prebuild step still works but is rate-limited to 60 req/hr.
# With it: 5000 req/hr. Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional: override the GitHub username (defaults to "Keshav-Madhav")
GITHUB_USERNAME=Keshav-Madhav

# -----------------------------------------------------------------------------
# Resend — contact form email delivery
# -----------------------------------------------------------------------------
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
