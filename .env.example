# =============================================================================
# Portfolio environment variables — copy to .env.local and fill in.
# =============================================================================

# -----------------------------------------------------------------------------
# Ably — multiplayer cursors + reactions (free 6M msgs/mo, no branding)
# -----------------------------------------------------------------------------
# Sign up at https://ably.com → Apps → API Keys → copy the *root* key.
# Server-side only: never expose this in client code. The /api/ably/token
# route uses it to mint short-lived tokens for the browser.
ABLY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxx

# Build-time flag that gates the multiplayer feature on. Without this set to
# "1", the cursor/reaction layer renders nothing — useful while developing
# offline or if you want to ship without it temporarily.
NEXT_PUBLIC_MULTIPLAYER_ENABLED=1

# -----------------------------------------------------------------------------
# Resend — contact form email delivery
# -----------------------------------------------------------------------------
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
