# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.claude/settings.local.json
CLAUDE.local.md

# Generated at build time by scripts/fetch-github.mjs
lib/keshav-context.generated.ts

# NOTE: lib/context-embeddings.json is intentionally NOT ignored.
# It's the pre-computed RAG vector store — committed so production builds
# use prestored embeddings rather than re-embedding on cold start.
# Regenerate via `npm run build-embeddings` when the corpus source changes.


.env*